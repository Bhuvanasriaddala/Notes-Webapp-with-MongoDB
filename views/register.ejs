<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    body {
      background: #f3f6fb;
      font-family: 'Segoe UI', Arial, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
    }
    .auth-form {
      background: #fff;
      padding: 2rem 2.5rem;
      border-radius: 10px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.1);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      max-width: 400px;
    }
    .auth-form input, .auth-form textarea {
      padding: 0.75rem 1rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 1rem;
      background: #f9fafb;
      transition: border 0.2s;
    }
    .auth-form input:focus, .auth-form textarea:focus {
      border: 1.5px solid #4f8cff;
      outline: none;
      background: #fff;
    }
    .auth-form button {
      background: #4f8cff;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 0.75rem 1rem;
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.2s;
    }
    .auth-form button:hover {
      background: #2563eb;
    }
    h2 {
      color: #2563eb;
      margin-bottom: 1rem;
    }
    ul {
      list-style: none;
      padding: 0;
    }
    ul li {
      color: #e11d48;
      margin-bottom: 0.25rem;
    }
    p {
      margin-top: 1.5rem;
      color: #374151;
    }
    a {
      color: #4f8cff;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <h2>Register</h2>
  <% if (errors.length > 0) { %>
    <ul style="color: red;">
      <% errors.forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>
  <form class="auth-form" action="/register" method="POST">
    <input type="text" name="username" placeholder="Username" value="<%= oldInput.username || '' %>" required>
    <input type="email" name="email" placeholder="Email" value="<%= oldInput.email || '' %>" required>
    <input type="password" name="password" placeholder="Password" required>
    <textarea name="comment" placeholder="Comment (optional)" maxlength="200"><%= oldInput.comment || '' %></textarea>
    <button type="submit">Register</button>
  </form>
  <p>Already have an account? <a href="/login">Login</a></p>
</body>
</html>
